TENCENTCLOUD_REGION=ap-guangzhou
JENKINS_ALLOWED_ORIGINS=https://jenkins.example.com
CACHE_TTL_SECONDS=25
QUERY_WINDOW_SECONDS=120
METRIC_PERIOD_SECONDS=300
REQUEST_TIMEOUT_SECONDS=10

# Recommended: mount root-only files into /run/secrets and use *_FILE
TENCENTCLOUD_SECRET_ID_FILE=/run/secrets/tencentcloud_secret_id
TENCENTCLOUD_SECRET_KEY_FILE=/run/secrets/tencentcloud_secret_key

SSH_USERNAME=hanglu
SSH_PORT=22
SSH_CONNECT_TIMEOUT_SECONDS=3
SSH_COMMAND_TIMEOUT_SECONDS=3
SSH_PRIVATE_KEY_PATH=/run/secrets/id_ed25519
SSH_PRIVATE_KEY_PASSPHRASE_FILE=/run/secrets/ssh_key_passphrase
SSH_KNOWN_HOSTS_PATH=/run/secrets/known_hosts
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_ALLOW_AGENT=false

# Fallback if you still need password auth:
# SSH_PASSWORD_FILE=/run/secrets/ssh_password
