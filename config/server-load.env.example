TENCENTCLOUD_REGION=ap-guangzhou
SERVER_CONFIG_PATH=/opt/cvm-load-panel/config/servers.json
JENKINS_ALLOWED_ORIGINS=https://jenkins.example.com
CACHE_TTL_SECONDS=25
QUERY_WINDOW_SECONDS=120
METRIC_PERIOD_SECONDS=300
REQUEST_TIMEOUT_SECONDS=10

# Recommended: store secrets in root-only files and read them with *_FILE
TENCENTCLOUD_SECRET_ID_FILE=/opt/cvm-load-panel/secrets/tencentcloud_secret_id
TENCENTCLOUD_SECRET_KEY_FILE=/opt/cvm-load-panel/secrets/tencentcloud_secret_key

SSH_USERNAME=hanglu
SSH_PORT=22
SSH_CONNECT_TIMEOUT_SECONDS=3
SSH_COMMAND_TIMEOUT_SECONDS=3
SSH_PRIVATE_KEY_PATH=/opt/cvm-load-panel/secrets/id_ed25519
SSH_PRIVATE_KEY_PASSPHRASE_FILE=/opt/cvm-load-panel/secrets/ssh_key_passphrase
SSH_KNOWN_HOSTS_PATH=/opt/cvm-load-panel/secrets/known_hosts
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_ALLOW_AGENT=false

# Fallback if you still need password auth:
# SSH_PASSWORD_FILE=/opt/cvm-load-panel/secrets/ssh_password
